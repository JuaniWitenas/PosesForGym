#!/usr/bin/env python3
"""Reusable YOLO26n pose inference script."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run Ultralytics YOLO26n pose inference on an image, video, URL, or webcam."
    )
    parser.add_argument(
        "--model",
        default="yolo26n-pose.pt",
        help="Model path or model name (default: yolo26n-pose.pt).",
    )
    parser.add_argument(
        "--source",
        default="https://ultralytics.com/images/bus.jpg",
        help="Input source: image/video path, URL, folder, or webcam index (default sample image URL).",
    )
    parser.add_argument(
        "--project",
        default="YOLO Pose",
        help="Project directory for prediction outputs (default: YOLO Pose).",
    )
    parser.add_argument(
        "--name",
        default="predict",
        help="Run name under the project directory (default: predict).",
    )
    parser.add_argument(
        "--imgsz",
        type=int,
        default=640,
        help="Inference image size in pixels (default: 640).",
    )
    parser.add_argument(
        "--conf",
        type=float,
        default=0.25,
        help="Confidence threshold (default: 0.25).",
    )
    parser.add_argument(
        "--iou",
        type=float,
        default=0.7,
        help="NMS IoU threshold (default: 0.7).",
    )
    parser.add_argument(
        "--device",
        default=None,
        help="Device to run on, e.g. cpu, 0, 0,1 (default: auto).",
    )
    parser.add_argument(
        "--save",
        dest="save",
        action="store_true",
        default=True,
        help="Save visualized outputs (default: enabled).",
    )
    parser.add_argument(
        "--no-save",
        dest="save",
        action="store_false",
        help="Do not save visualized outputs.",
    )
    parser.add_argument(
        "--show",
        action="store_true",
        help="Display live prediction window.",
    )
    parser.add_argument(
        "--save-txt",
        action="store_true",
        help="Save predictions to txt labels.",
    )
    parser.add_argument(
        "--save-conf",
        action="store_true",
        help="Save confidence scores in txt labels.",
    )
    parser.add_argument(
        "--exist-ok",
        action="store_true",
        help="Allow existing project/name directory.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    try:
        from ultralytics import YOLO
    except ImportError:
        print(
            "Ultralytics is not installed. Install it with: python -m pip install ultralytics",
            file=sys.stderr,
        )
        return 1

    model = YOLO(args.model)

    results = model.predict(
        source=args.source,
        imgsz=args.imgsz,
        conf=args.conf,
        iou=args.iou,
        device=args.device,
        save=args.save,
        show=args.show,
        save_txt=args.save_txt,
        save_conf=args.save_conf,
        project=args.project,
        name=args.name,
        exist_ok=args.exist_ok,
        verbose=True,
    )

    if not results:
        print("No results returned.")
        return 0

    save_dir = getattr(results[0], "save_dir", None)
    if args.save and save_dir:
        print(f"Saved outputs to: {Path(save_dir)}")
    elif not args.save:
        print("Saving disabled (--no-save).")

    # Access pose keypoint outputs in the same structure as Ultralytics examples.
    for idx, result in enumerate(results, start=1):
        if result.keypoints is None:
            print(f"Result {idx}: no keypoints detected.")
            continue

        xy = result.keypoints.xy
        xyn = result.keypoints.xyn
        kpts = result.keypoints.data

        print(
            f"Result {idx}: keypoints xy={tuple(xy.shape)}, "
            f"xyn={tuple(xyn.shape)}, data={tuple(kpts.shape)}"
        )

    total_boxes = sum(len(r.boxes) if r.boxes is not None else 0 for r in results)
    print(f"Processed {len(results)} input(s). Total detections: {total_boxes}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
